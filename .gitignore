# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Environment variables — contain real secrets (JWT_SECRET, DB URI, Daraja
# keys, Gemini/Vertex AI credentials, etc.). Never commit these.
.env
.env.local
.env.*.local
backend/.env
frontend/.env
frontend/.env.sandbox

# User-uploaded content (meter reading photos etc.) — not source, and can
# contain resident-identifying images.
backend/uploads/
uploads/

# Frontend production build output
frontend/build/
build/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Coverage / test output
coverage/

# OS files
.DS_Store
Thumbs.db

# Editor/IDE
.vscode/
.idea/
*.swp
