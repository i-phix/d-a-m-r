# Copy this file to .env and fill in real values. Never commit .env itself
# (see repo-root .gitignore).

PORT=5050
ALLOWED_ORIGINS=http://localhost:3000

# MongoDB
MONGODB_DB_NAME=damr_database
MONGODB_SECURED=false
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# File uploads (meter photos)
UPLOADS_DIR=./uploads

# Used server-side to build the public bill/statement links included in
# notifications (must be reachable by residents, i.e. the frontend's URL).
FRONTEND_BASE_URL=http://localhost:3000

# Google Vision — used only by the meter "scan nameplate" flow
# (serial/manufacturer/model at registration time), not reading OCR.
GOOGLE_VISION_API_KEY=

# Gemini vision meter-reading OCR
AI_MESSAGES_ENABLED=true
GEMINI_MODEL=gemini-2.5-flash

# Gemini runs through Vertex AI, authenticated via Application Default
# Credentials (gcloud auth application-default login locally, or
# GOOGLE_APPLICATION_CREDENTIALS pointing at a service-account JSON on a
# real server) — no API key needed here.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

GOOGLE_TRANSLATE_API_KEY=
GOOGLE_PLACES_API_KEY=

# M-Pesa / Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Base origin only — mpesaService.js appends the callback path itself.
MPESA_CALLBACK_BASE_URL=https://your-api-domain.example.com

# Email / SMS / WhatsApp notifications
COMMUNICATIONS_ENDPOINT=
SENDERID=
API_KEY=
DAMR_SMS_FACILITY_ID=
EMAIL_SENDER=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_SENDER_NAME=
DAMR_EMAIL_FACILITY_ID=
UTILITY_WHATSAPP_ENABLED=true

MAIN_BACKEND_URL=
INTERNAL_SERVICE_TOKEN=

# Fallback recipient for facility-level alerts when a facility has no
# admin/FM user yet.
ADMIN_EMAIL=
