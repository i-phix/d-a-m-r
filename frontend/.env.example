# Used by utils/urls.js — uncomment the line you need in that file directly,
# or wire this in if you switch urls.js to read from process.env.
REACT_APP_BACKEND_URL=http://localhost:5050

# First third of the Google Places API key — see src/config/mapsKeyParts.js
# and src/utils/googleMapsKey.js for how the other two-thirds are combined
# with this at runtime. Address autocomplete silently disables itself if
# this is missing.
REACT_APP_GOOGLE_PLACES_KEY_SEED=
